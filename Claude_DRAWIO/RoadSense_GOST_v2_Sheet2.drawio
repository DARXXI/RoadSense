    <!-- [C] Вероятность ДТП — ПОДПРОЦЕСС -->
    <mxCell id="b_C" value="p = base × K_w × K_s × K_t&lt;br&gt;clearance = 37×(1+d/30)×K_w мин&lt;br&gt;R = p × clearance" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
