    <!-- [B] Скорость сегмента — ПОДПРОЦЕСС -->
    <mxCell id="b_B" value="V_ij = V₀ × K_surf × K_weather × K_time&lt;br&gt;V₀ = 90 км/ч" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
