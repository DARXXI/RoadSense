    <!-- Возврат из задержки к T_seg -->
    <mxCell id="e_jam_e" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" source="b_jam" target="b_E" parent="1">
