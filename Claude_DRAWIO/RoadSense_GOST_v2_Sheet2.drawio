    <!-- [E] T_seg — обычный процесс -->
    <mxCell id="b_E" value="T_seg = l/V_ij + A×C + R&lt;br&gt;(Формула модели)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
