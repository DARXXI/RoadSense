    <mxCell id="form_main" value="&lt;font style=&quot;font-size:18px;&quot; color=&quot;#1A3A5C&quot;&gt;&lt;b&gt;T = l/v + A·C + p·t&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
