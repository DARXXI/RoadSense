    <!-- [B_end] Конец этапа B — перевёрнутая трапеция -->
    <mxCell id="hex_B_end" value="&lt;b&gt;B&lt;/b&gt;  j = j + 1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="150" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Петля возврата к hex_B_start (на листе 1) — рисуем как стрелку вправо с подписью -->
    <mxCell id="note_loop_B" value="→ возврат к началу этапа B (лист 1)&lt;br&gt;если j &lt; m" style="text;html=1;fontSize=8.5;fontStyle=2;fontColor=#AA0000;align=left;" vertex="1" parent="1">
