    </mxCell>

    <mxCell id="e_B_end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_B_end" target="hex_C_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ─── ЭТАП C — РАСЧЁТ ВРЕМЕНИ СЕГМЕНТА ─── -->

    <!-- [C_start] Начало этапа C -->
    <mxCell id="hex_C_start" value="&lt;b&gt;C&lt;/b&gt;  пока i &lt; n" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=0;" vertex="1" parent="1">
