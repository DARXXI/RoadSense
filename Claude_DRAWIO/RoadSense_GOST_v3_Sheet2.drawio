    <!-- [C4] T_seg -->
    <mxCell id="b_tseg" value="T_seg = l/V_ij + A×C + R" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
