    <mxCell id="e_D1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_D_start" target="b_2opt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [D1] 2-opt — ПОДПРОЦЕСС -->
    <mxCell id="b_2opt" value="2-opt: swap(i,j) if T_new &lt; T_best&lt;br&gt;→ best_route, best_time" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="602" width="210" height="48" as="geometry"/>
    </mxCell>

    <!-- Раскрытие 2-opt -->
    <mxCell id="note_2opt" value="&lt;b&gt;Детали подпроцесса:&lt;/b&gt;&lt;br&gt;∀ i ∈ [0,n-2], j ∈ [i+1,n-1]:&lt;br&gt;  swap route[i] ↔ route[j]&lt;br&gt;  если T_new &lt; T_best → принять&lt;br&gt;Сложность: O(n²) за итерацию&lt;br&gt;Макс. 100 итераций" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;strokeColor=#1565c0;strokeWidth=1;fillColor=#EEF5FF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="594" width="220" height="82" as="geometry"/>
    </mxCell>
    <mxCell id="e_note2opt" style="edgeStyle=none;dashed=1;strokeColor=#1565c0;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_2opt" target="b_2opt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_D1end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_2opt" target="hex_D_end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [D_end] Конец этапа D — перевёрнутая трапеция -->
    <mxCell id="hex_D_end" value="&lt;b&gt;D&lt;/b&gt;  iter = iter + 1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="662" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Петля 2-opt -->
