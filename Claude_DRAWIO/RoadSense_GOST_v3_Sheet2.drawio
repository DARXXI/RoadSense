    <!-- [F2] Вывод — параллелограмм -->
    <mxCell id="b_out" value="&lt;i&gt;Вывод: T [мин], best_route&lt;br&gt;pipeline_result.json&lt;/i&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=16;fillColor=#E2F0D9;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
