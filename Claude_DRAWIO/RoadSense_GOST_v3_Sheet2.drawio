    <mxCell id="e_noteC" style="edgeStyle=none;dashed=1;strokeColor=#AAAAAA;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_C" target="hex_C_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_C1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_C_start" target="b_speed" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [C1] Скорость сегмента — ПОДПРОЦЕСС -->
    <mxCell id="b_speed" value="V_ij = V₀ × K_surf × K_weather × K_time&lt;br&gt;V₀ = 90 км/ч" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="254" width="210" height="44" as="geometry"/>
    </mxCell>

    <!-- Раскрытие -->
    <mxCell id="note_spd" value="&lt;b&gt;Детали:&lt;/b&gt;&lt;br&gt;K_surf: из XGBoost (лист 1)&lt;br&gt;K_weather: fine=1.0, rain=0.8, heavy=0.65&lt;br&gt;K_time: peak=0.75, day=1.0, night=1.1" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;strokeColor=#1565c0;strokeWidth=1;fillColor=#EEF5FF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="248" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e_noteSpd" style="edgeStyle=none;dashed=1;strokeColor=#1565c0;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_spd" target="b_speed" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_C12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_speed" target="b_risk" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [C2] Вероятность ДТП — ПОДПРОЦЕСС -->
    <mxCell id="b_risk" value="Вероятность ДТП&lt;br&gt;p = base × K_w × K_s × K_t&lt;br&gt;clearance = 37×(1+d/30)×K_w мин&lt;br&gt;R = p × clearance" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="310" width="210" height="56" as="geometry"/>
    </mxCell>

    <!-- Раскрытие ДТП -->
    <mxCell id="note_risk" value="&lt;b&gt;Детали:&lt;/b&gt;&lt;br&gt;base = 0.003, police_dist = 10 км&lt;br&gt;K_w (дождь=1.4, ливень=1.8)&lt;br&gt;K_s (грунт=1.5, песок=1.8)&lt;br&gt;K_t (пиковый час=1.5)&lt;br&gt;p = min(0.08, base×K_w×K_s×K_t)" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;strokeColor=#1565c0;strokeWidth=1;fillColor=#EEF5FF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="302" width="220" height="82" as="geometry"/>
