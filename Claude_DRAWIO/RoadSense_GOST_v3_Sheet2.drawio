    <mxCell id="e_D_final" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_D_end" target="b_eta" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ─── ФИНАЛ ─── -->
    <!-- [F1] ETA -->
    <mxCell id="b_eta" value="T = Σ T_seg_i  [мин]&lt;br&gt;ETA = t_отправления + T" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="25" y="714" width="210" height="44" as="geometry"/>
    </mxCell>
