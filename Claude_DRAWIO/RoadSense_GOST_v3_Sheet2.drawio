    <!-- ═══════════════════════════════════════════════════════
         ПРАВАЯ ПАНЕЛЬ — формула + speed_factor
         ═══════════════════════════════════════════════════════ -->

    <!-- Рамка формулы -->
    <mxCell id="form_bg" value="" style="rounded=1;fillColor=#FFFDF0;strokeColor=#1A3A5C;strokeWidth=1.5;" vertex="1" parent="1">
      <mxGeometry x="510" y="42" width="300" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="form_title" value="&lt;b&gt;Основная формула модели&lt;/b&gt;" style="text;html=1;fontSize=9.5;fontColor=#1A3A5C;" vertex="1" parent="1">
      <mxGeometry x="520" y="48" width="280" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="form_main" value="&lt;font style=&quot;font-size:19px;&quot; color=&quot;#1A3A5C&quot;&gt;&lt;b&gt;T = l/v + A·C + p·t&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="510" y="68" width="300" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="form_d1" value="&lt;b&gt;l/v&lt;/b&gt; — чистое время движения" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="104" width="280" height="18" as="geometry"/></mxCell>
    <mxCell id="form_d2" value="&lt;b&gt;A·C&lt;/b&gt; — задержка от пробок / ДТП" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="122" width="280" height="18" as="geometry"/></mxCell>
    <mxCell id="form_d3" value="&lt;b&gt;p·t&lt;/b&gt; — ожидаемая задержка ДТП" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="140" width="280" height="18" as="geometry"/></mxCell>
    <mxCell id="form_v"  value="&lt;i&gt;V_ij = V₀ × K_surf × K_weather × K_time&lt;/i&gt;" style="text;html=1;fontSize=9;fontColor=#444444;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="162" width="280" height="18" as="geometry"/></mxCell>
    <mxCell id="form_r"  value="&lt;i&gt;R = p(accident) × clearance_time&lt;/i&gt;" style="text;html=1;fontSize=9;fontColor=#444444;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="180" width="280" height="18" as="geometry"/></mxCell>
    <mxCell id="form_gost" value="ГОСТ 19.701-90" style="text;html=1;fontSize=8;fontColor=#999999;fontStyle=2;align=center;" vertex="1" parent="1"><mxGeometry x="520" y="214" width="280" height="16" as="geometry"/></mxCell>

