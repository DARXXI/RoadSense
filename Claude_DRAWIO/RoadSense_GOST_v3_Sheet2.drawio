    <!-- [F3] КОНЕЦ -->
    <mxCell id="b_end" value="&lt;b&gt;КОНЕЦ&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1A3A5C;strokeColor=#000000;strokeWidth=2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="822" width="210" height="36" as="geometry"/>
