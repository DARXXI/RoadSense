    </mxCell>

    <!-- Пояснение этапа C -->
    <mxCell id="note_C" value="n — количество сегментов маршрута&lt;br&gt;i — счётчик текущего сегмента&lt;br&gt;Цикл: расчёт времени для каждого&lt;br&gt;сегмента по формуле T = l/v + A·C + p·t" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;strokeColor=#AAAAAA;strokeWidth=1;fillColor=#FAFAFA;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="196" width="220" height="60" as="geometry"/>
