    <mxCell id="e_67" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_features" target="b_xgb" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [7] XGBoost — ПОДПРОЦЕСС -->
    <mxCell id="b_xgb" value="XGBoost.predict()&lt;br&gt;→ surface_class&lt;br&gt;+ speed_factor [0.6–1.0]" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
