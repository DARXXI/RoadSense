    <mxCell id="e_56" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_mosaic" target="b_features" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

