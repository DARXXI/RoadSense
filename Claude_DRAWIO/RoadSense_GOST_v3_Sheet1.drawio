<mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="0" page="1" pageScale="1" pageWidth="1277" pageHeight="720" math="0" shadow="0" background="#FFFFFF">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ЗАГОЛОВОК -->
    <mxCell id="title" value="Блок-схема алгоритма RoadSense Pipeline  (Лист 1 / 2)" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#1A3A5C;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="5" width="840" height="26" as="geometry"/>
    </mxCell>
    <mxCell id="title_line" value="" style="line;strokeColor=#1A3A5C;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="33" width="1237" height="2" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         ГЛАВНАЯ КОЛОНКА  cx=130, w=210
         Все Y от 42 вниз
         ═══════════════════════════════════════════════════════ -->

    <!-- [1] НАЧАЛО — овал -->
    <mxCell id="b_start" value="&lt;b&gt;НАЧАЛО&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1A3A5C;strokeColor=#000000;strokeWidth=2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="42" width="210" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="e_s1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_start" target="b_gps" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [2] Ввод GPS — параллелограмм (ввод) -->
    <mxCell id="b_gps" value="&lt;i&gt;Ввод: GPS-трек (.gpx)&lt;br&gt;lat, lon, n точек&lt;/i&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=16;fillColor=#E2F0D9;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="25" y="90" width="210" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="e_12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_gps" target="hex_A_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ───────────────────────────────────────────────────────
         ЭТАП A — ЗАГРУЗКА СНИМКОВ
         Начало = шестиугольная трапеция (mxgraph: trapezoid + перевёрнутая)
         В draw.io: shape=mxgraph.flowchart.start_2  — это именно «усечённая пирамида»
         Стандарт ГОСТ — используем shape=hexagon для метки начала этапа
         ─────────────────────────────────────────────────────── -->

    <!-- [A_start] Начало этапа — шестиугольная трапеция (усечённый верх) -->
    <!-- В draw.io стандартный shape для этого = shape=trapezoid (перевёрнутая) -->
    <mxCell id="hex_A_start" value="&lt;b&gt;A&lt;/b&gt;  пока i &lt; n" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=0;" vertex="1" parent="1">
      <mxGeometry x="25" y="142" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Пояснение этапа A сбоку -->
    <mxCell id="note_A" value="N — количество точек GPS-трека&lt;br&gt;i — счётчик текущей точки&lt;br&gt;Цикл: загрузка снимка, мозаика,&lt;br&gt;признаки, XGBoost для каждой точки" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;strokeColor=#AAAAAA;strokeWidth=1;fillColor=#FAFAFA;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="138" width="210" height="64" as="geometry"/>
    </mxCell>
    <!-- Пунктирная связь -->
    <mxCell id="e_noteA" style="edgeStyle=none;dashed=1;strokeColor=#AAAAAA;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_A" target="hex_A_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_A1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_A_start" target="b_download" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [3] Загрузка снимков — ПОДПРОЦЕСС (двойной прямоугольник) -->
    <mxCell id="b_download" value="Загрузка спутн. снимков&lt;br&gt;LINZ API, zoom 18–19&lt;br&gt;deg_to_tile → XYZ tiles" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
