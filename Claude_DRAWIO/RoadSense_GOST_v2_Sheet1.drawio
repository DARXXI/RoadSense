    <mxCell id="lg1t" value="— Начало / Конец" style="text;html=1;fontSize=8.5;" vertex="1" parent="1"><mxGeometry x="730" y="398" width="145" height="20" as="geometry"/></mxCell>

    <!-- Процесс -->
    <mxCell id="lg2" value="" style="rounded=0;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="678" y="424" width="46" height="20" as="geometry"/></mxCell>
    <mxCell id="lg2t" value="— Процесс" style="text;html=1;fontSize=8.5;" vertex="1" parent="1"><mxGeometry x="730" y="424" width="145" height="20" as="geometry"/></mxCell>

    <!-- Подпроцесс (двойная граница) -->
    <mxCell id="lg3" value="" style="shape=process;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1;backgroundOutline=1;" vertex="1" parent="1"><mxGeometry x="678" y="450" width="46" height="20" as="geometry"/></mxCell>
    <mxCell id="lg3t" value="— Подпроцесс (двойная граница)" style="text;html=1;fontSize=8.5;" vertex="1" parent="1"><mxGeometry x="730" y="450" width="220" height="20" as="geometry"/></mxCell>

    <!-- Решение -->
    <mxCell id="lg4" value="" style="rhombus;fillColor=#FFF5CC;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="678" y="474" width="46" height="28" as="geometry"/></mxCell>
    <mxCell id="lg4t" value="— Решение" style="text;html=1;fontSize=8.5;" vertex="1" parent="1"><mxGeometry x="730" y="480" width="145" height="20" as="geometry"/></mxCell>

    <!-- Ввод/Вывод -->
    <mxCell id="lg5" value="" style="shape=parallelogram;perimeter=parallelogramPerimeter;fixedSize=1;size=8;fillColor=#E2F0D9;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="678" y="508" width="46" height="20" as="geometry"/></mxCell>
    <mxCell id="lg5t" value="— Ввод / Вывод" style="text;html=1;fontSize=8.5;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="730" y="508" width="145" height="20" as="geometry"/></mxCell>

