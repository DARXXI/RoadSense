    <!-- [8] Open-Meteo — ПОДПРОЦЕСС -->
    <mxCell id="b_weather" value="Open-Meteo API&lt;br&gt;precipitation → weather&lt;br&gt;{fine / rain / heavy_rain}" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
