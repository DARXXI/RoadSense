      <mxGeometry x="670" y="270" width="130" height="48" as="geometry"/>
    </mxCell>
    <mxCell id="hex_B_note" value="Цикл по сегментам маршрута:&lt;br&gt;j = 0..m−1&lt;br&gt;Запрос Open-Meteo → K_weather → K_time" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;" vertex="1" parent="1">
      <mxGeometry x="812" y="268" width="230" height="52" as="geometry"/>
