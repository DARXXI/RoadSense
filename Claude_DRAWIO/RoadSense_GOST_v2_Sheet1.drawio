    </mxCell>

    <!-- [9] NZTA Traffic — ПОДПРОЦЕСС -->
    <mxCell id="b_traffic" value="NZTA Traffic API&lt;br&gt;congestion → K_time&lt;br&gt;{peak / day / night}" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="430" y="218" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- [10] Pearson r -->
    <mxCell id="b_pearson" value="Pearson r&lt;br&gt;weather ↔ delay&lt;br&gt;surface ↔ delay" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="430" y="284" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- Вертикальные стрелки между погодными блоками -->
    <mxCell id="e_wt" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_weather" target="b_traffic" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e_tp" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_traffic" target="b_pearson" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ══════════════════════════════════════════════════════
         ШИНА СЛИЯНИЯ (Y=500)
         ══════════════════════════════════════════════════════ -->

    <!-- Точки шины -->
    <mxCell id="pt_left"   value="" style="point;strokeColor=none;fillColor=none;" vertex="1" parent="1"><mxGeometry x="115" y="500" width="2" height="2" as="geometry"/></mxCell>
    <mxCell id="pt_right"  value="" style="point;strokeColor=none;fillColor=none;" vertex="1" parent="1"><mxGeometry x="530" y="500" width="2" height="2" as="geometry"/></mxCell>
