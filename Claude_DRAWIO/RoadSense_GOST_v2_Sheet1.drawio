<mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="0" page="1" pageScale="1" pageWidth="1277" pageHeight="720" math="0" shadow="0" background="#FFFFFF">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ЗАГОЛОВОК -->
    <mxCell id="title" value="Блок-схема алгоритма RoadSense Pipeline  (Лист 1 / 2)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#1A3A5C;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="6" width="1050" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="title_line" value="" style="line;strokeColor=#1A3A5C;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="36" width="1050" height="2" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════
         ПОТОК: вертикальная левая колонка → слияние → ①
         Центр колонки: cx=115, блоки w=200
         ══════════════════════════════════════════════════════ -->

    <!-- [1] НАЧАЛО -->
    <mxCell id="b_start" value="&lt;b&gt;НАЧАЛО&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1A3A5C;strokeColor=#000000;strokeWidth=2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="15" y="46" width="200" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="e_s1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_start" target="b_gps" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [2] Ввод GPS — параллелограмм (ввод/вывод) -->
    <mxCell id="b_gps" value="&lt;i&gt;Ввод: GPS-трек (.gpx)&lt;br&gt;lat, lon, n точек&lt;/i&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=15;fillColor=#E2F0D9;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="15" y="96" width="200" height="42" as="geometry"/>
    </mxCell>
    <mxCell id="e_12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_gps" target="b_download" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [3] Загрузка спутн. снимков — ПОДПРОЦЕСС (двойная граница) -->
    <mxCell id="b_download" value="Загрузка спутн. снимков&lt;br&gt;LINZ API, zoom 18–19" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="15" y="152" width="200" height="44" as="geometry"/>
    </mxCell>
    <mxCell id="e_23" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_download" target="b_loaded" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [4] Снимок загружен? — РОМБ -->
    <mxCell id="b_loaded" value="Снимок&lt;br&gt;загружен?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF5CC;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="15" y="210" width="200" height="58" as="geometry"/>
    </mxCell>

    <!-- Нет → Пропуск точки -->
    <mxCell id="b_skip" value="Пропуск точки / следующая" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="222" width="185" height="34" as="geometry"/>
    </mxCell>
    <mxCell id="e_no" value="Нет" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;fontSize=9;fontStyle=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="b_loaded" target="b_skip" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- Нет → возврат наверх к Download -->
    <mxCell id="e_skip_back" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=0;entryX=1;entryY=0.5;" edge="1" source="b_skip" target="b_download" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="332" y="170"/>
          <mxPoint x="215" y="170"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Да → вниз -->
    <mxCell id="e_yes" value="Да" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;fontSize=9;fontStyle=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_loaded" target="b_mosaic" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [5] Мозаика 3×3 — ПОДПРОЦЕСС -->
    <mxCell id="b_mosaic" value="Мозаика 3×3 (768×768 px)&lt;br&gt;surface_cache[key]" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="15" y="282" width="200" height="44" as="geometry"/>
    </mxCell>
    <mxCell id="e_45" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_mosaic" target="b_features" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [6] Извлечение признаков — ПОДПРОЦЕСС -->
    <mxCell id="b_features" value="Извлечение признаков&lt;br&gt;RGB · HSV · LBP · GLCM&lt;br&gt;Canny · DarkSpot (50 feat.)" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="15" y="340" width="200" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e_56" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;" edge="1" source="b_features" target="b_xgb" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [7] XGBoost — ПОДПРОЦЕСС -->
    <mxCell id="b_xgb" value="XGBoost.predict()&lt;br&gt;→ surface_class&lt;br&gt;+ speed_factor [0.6–1.0]" style="shape=process;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="15" y="404" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════
