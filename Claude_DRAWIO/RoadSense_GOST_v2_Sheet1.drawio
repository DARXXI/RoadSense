    <!-- Стрелки от XGBoost и Pearson к шине -->
    <mxCell id="e_xgb_bus" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_xgb" target="pt_left" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e_prs_bus" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_pearson" target="pt_right" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Горизонтальная шина -->
    <mxCell id="bus" value="" style="line;strokeColor=#000000;strokeWidth=1.5;fillColor=none;" vertex="1" parent="1">
