    <!-- СОЕДИНИТЕЛЬ ① -->
    <mxCell id="conn1" value="&lt;b&gt;1&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFD700;strokeColor=#000000;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="304" y="516" width="36" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="conn1_lbl" value="→ продолжение на листе 2" style="text;html=1;fontSize=9;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
      <mxGeometry x="346" y="526" width="200" height="18" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════
