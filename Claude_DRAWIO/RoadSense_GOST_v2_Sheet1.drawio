    <!-- Шестиугольник «А — цикл по точкам» (между Download и шиной) -->
    <mxCell id="hex_A" value="&lt;b&gt;A&lt;/b&gt;&lt;br&gt;пока i &lt; n" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=10;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="670" y="200" width="130" height="48" as="geometry"/>
    </mxCell>
    <!-- Пояснение к шестиугольнику A -->
    <mxCell id="hex_A_note" value="Цикл по точкам GPS-трека:&lt;br&gt;i = 0..n−1&lt;br&gt;Загрузка снимка → мозаика → признаки → XGBoost" style="text;html=1;fontSize=8.5;fontColor=#333333;align=left;" vertex="1" parent="1">
