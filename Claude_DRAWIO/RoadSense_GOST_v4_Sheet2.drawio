    <mxCell id="e_c1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="conn1_in" target="b_pearson" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [0] Корреляционный анализ (продолж. этапа Б) -->
    <mxCell id="b_pearson" value="Корреляционный анализ (Пирсон)&lt;br&gt;погода ↔ задержка&lt;br&gt;покрытие ↔ задержка" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="25" y="90" width="210" height="50" as="geometry"/>
    </mxCell>

    <!-- Раскрытие Пирсона -->
    <mxCell id="note_prs" value="&lt;b&gt;Детали:&lt;/b&gt;&lt;br&gt;r(осадки, задержка) → интерпретация&lt;br&gt;r(покрытие, задержка) → интерпретация&lt;br&gt;r(время суток, задержка) → интерпретация&lt;br&gt;p-значение &lt; 0,05 — статистически значимо" style="text;html=1;fontSize=8.5;fontColor=#000000;align=left;strokeColor=#000000;strokeWidth=1;fillColor=#FFFFFF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="84" width="215" height="66" as="geometry"/>
    </mxCell>
    <mxCell id="e_notePrs" style="edgeStyle=none;dashed=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_prs" target="b_pearson" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_pr_bend" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_pearson" target="hex_B_end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Конец этапа Б — перевёрнутая трапеция -->
    <mxCell id="hex_B_end" value="&lt;b&gt;Б&lt;/b&gt;   j = j + 1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="152" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Примечание о возврате Б -->
    <mxCell id="note_loopB" value="← возврат к началу этапа Б (лист 1)&lt;br&gt;если j &lt; m" style="text;html=1;fontSize=8.5;fontStyle=2;fontColor=#000000;align=left;" vertex="1" parent="1">
      <mxGeometry x="258" y="160" width="200" height="28" as="geometry"/>
    </mxCell>

    <mxCell id="e_B_end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_B_end" target="hex_C_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ══════════════════════════════════════════
         ЭТАП В — РАСЧЁТ ВРЕМЕНИ СЕГМЕНТА
         ══════════════════════════════════════════ -->

    <!-- Начало этапа В -->
    <mxCell id="hex_C_start" value="&lt;b&gt;В&lt;/b&gt;   пока i &lt; n" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=0;" vertex="1" parent="1">
      <mxGeometry x="25" y="204" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Пояснение этапа В -->
    <mxCell id="note_C" value="n — количество сегментов маршрута&lt;br&gt;i — счётчик текущего сегмента&lt;br&gt;Цикл: расчёт времени для каждого&lt;br&gt;сегмента по формуле Т = l/v + А·С + р·t" style="text;html=1;fontSize=8.5;fontColor=#000000;align=left;strokeColor=#000000;strokeWidth=1;fillColor=#FFFFFF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="198" width="215" height="58" as="geometry"/>
    </mxCell>
    <mxCell id="e_noteC" style="edgeStyle=none;dashed=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_C" target="hex_C_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_C1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_C_start" target="b_speed" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [В1] Скорость сегмента — подпроцесс -->
    <mxCell id="b_speed" value="Расчёт скорости сегмента&lt;br&gt;V = V₀ × К_покр × К_погода × К_время&lt;br&gt;V₀ = 90 км/ч" style="shape=process;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="256" width="210" height="50" as="geometry"/>
    </mxCell>

    <!-- Раскрытие скорости -->
    <mxCell id="note_spd" value="&lt;b&gt;Детали подпроцесса:&lt;/b&gt;&lt;br&gt;К_покр: из классификатора (лист 1)&lt;br&gt;К_погода: ясно=1,0, дождь=0,8, ливень=0,65&lt;br&gt;К_время: пик=0,75, день=1,0, ночь=1,1" style="text;html=1;fontSize=8.5;fontColor=#000000;align=left;strokeColor=#000000;strokeWidth=1;fillColor=#FFFFFF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="250" width="215" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e_noteSpd" style="edgeStyle=none;dashed=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_spd" target="b_speed" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_C12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_speed" target="b_risk" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [В2] Вероятность ДТП — подпроцесс -->
    <mxCell id="b_risk" value="Расчёт вероятности ДТП&lt;br&gt;р = базовый × К_п × К_пк × К_в&lt;br&gt;время устранения = 37×(1+d/30)×К_п мин&lt;br&gt;R = р × время устранения" style="shape=process;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="318" width="210" height="58" as="geometry"/>
    </mxCell>

    <!-- Раскрытие ДТП -->
    <mxCell id="note_risk" value="&lt;b&gt;Детали подпроцесса:&lt;/b&gt;&lt;br&gt;базовый риск = 0,003&lt;br&gt;расстояние до полиции = 10 км&lt;br&gt;К_п (дождь=1,4, ливень=1,8)&lt;br&gt;К_пк (грунт=1,5, песок=1,8)&lt;br&gt;К_в (час пик=1,5)&lt;br&gt;р = min(0,08; базовый×К_п×К_пк×К_в)" style="text;html=1;fontSize=8.5;fontColor=#000000;align=left;strokeColor=#000000;strokeWidth=1;fillColor=#FFFFFF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="308" width="215" height="90" as="geometry"/>
    </mxCell>
    <mxCell id="e_noteRisk" style="edgeStyle=none;dashed=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_risk" target="b_risk" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_C23" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_risk" target="b_active" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [В3] Активная авария? — ромб -->
    <mxCell id="b_active" value="случ() &lt; 0,03&lt;br&gt;(активная авария)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="25" y="388" width="210" height="56" as="geometry"/>
    </mxCell>

    <!-- Да → задержка пробки -->
    <mxCell id="b_jam" value="Задержка пробки&lt;br&gt;А×С = случ(8..25) мин" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="258" y="398" width="175" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="e_jam" value="Да" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;fontSize=9;fontStyle=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="b_active" target="b_jam" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e_jam_ret" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" source="b_jam" target="b_tseg" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="345" y="462"/>
          <mxPoint x="235" y="462"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e_no_jam" value="Нет" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;fontSize=9;fontStyle=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_active" target="b_tseg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [В4] Расчёт T_сег -->
    <mxCell id="b_tseg" value="Т_сег = l/V + А×С + R&lt;br&gt;(основная формула модели)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="456" width="210" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="e_C4end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_tseg" target="hex_C_end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Конец этапа В — перевёрнутая трапеция -->
    <mxCell id="hex_C_end" value="&lt;b&gt;В&lt;/b&gt;   i = i + 1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="508" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Петля возврата В -->
    <mxCell id="e_loop_C" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="hex_C_end" target="hex_C_start" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="5" y="528"/>
          <mxPoint x="5" y="224"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <mxCell id="e_C_D" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_C_end" target="hex_D_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ══════════════════════════════════════════
         ЭТАП Г — ОПТИМИЗАЦИЯ МАРШРУТА (2-ОПТ)
         ══════════════════════════════════════════ -->

    <!-- Начало этапа Г -->
    <mxCell id="hex_D_start" value="&lt;b&gt;Г&lt;/b&gt;   пока есть улучшение" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=0;" vertex="1" parent="1">
      <mxGeometry x="25" y="560" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Пояснение этапа Г -->
    <mxCell id="note_D" value="Условие выхода: нет улучшения&lt;br&gt;ИЛИ число итераций ≥ 100&lt;br&gt;Перебор всех пар (i,j), O(n²) на итерацию" style="text;html=1;fontSize=8.5;fontColor=#000000;align=left;strokeColor=#000000;strokeWidth=1;fillColor=#FFFFFF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="554" width="215" height="52" as="geometry"/>
    </mxCell>
    <mxCell id="e_noteD" style="edgeStyle=none;dashed=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_D" target="hex_D_start" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_D1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_D_start" target="b_2opt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [Г1] Оптимизация 2-опт — подпроцесс -->
    <mxCell id="b_2opt" value="Оптимизация 2-опт&lt;br&gt;перестановка(i,j) если Т_нов &lt; Т_лучш&lt;br&gt;→ лучший маршрут, лучшее время" style="shape=process;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;backgroundOutline=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="612" width="210" height="50" as="geometry"/>
    </mxCell>

    <!-- Раскрытие 2-опт -->
    <mxCell id="note_2opt" value="&lt;b&gt;Детали подпроцесса:&lt;/b&gt;&lt;br&gt;∀ i ∈ [0,n-2], j ∈ [i+1,n-1]:&lt;br&gt;  переставить маршрут[i] ↔ маршрут[j]&lt;br&gt;  если Т_нов &lt; Т_лучш → принять&lt;br&gt;Сложность: O(n²) за итерацию&lt;br&gt;Максимум 100 итераций" style="text;html=1;fontSize=8.5;fontColor=#000000;align=left;strokeColor=#000000;strokeWidth=1;fillColor=#FFFFFF;dashed=1;dashPattern=4 3;" vertex="1" parent="1">
      <mxGeometry x="258" y="604" width="215" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="e_note2opt" style="edgeStyle=none;dashed=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=none;" edge="1" source="note_2opt" target="b_2opt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell id="e_D1end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_2opt" target="hex_D_end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Конец этапа Г — перевёрнутая трапеция -->
    <mxCell id="hex_D_end" value="&lt;b&gt;Г&lt;/b&gt;   итер = итер + 1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=1;flipV=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="674" width="210" height="40" as="geometry"/>
    </mxCell>

    <!-- Петля 2-опт -->
    <mxCell id="e_loop_D" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="hex_D_end" target="hex_D_start" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="252" y="694"/>
          <mxPoint x="252" y="580"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <mxCell id="e_D_final" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="hex_D_end" target="b_eta" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [Ф1] Итоговый расчёт ВПП -->
    <mxCell id="b_eta" value="Т = Σ Т_сег_i  [мин]&lt;br&gt;ВПП = время отправления + Т" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="25" y="726" width="210" height="44" as="geometry"/>
    </mxCell>
    <mxCell id="e_eta_out" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_eta" target="b_out" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [Ф2] Вывод — параллелограмм -->
    <mxCell id="b_out" value="&lt;i&gt;Вывод: Т [мин], оптим. маршрут&lt;br&gt;результат_конвейера.json&lt;/i&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=16;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="25" y="782" width="210" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="e_out_end" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="b_out" target="b_end" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- [Ф3] КОНЕЦ -->
    <mxCell id="b_end" value="&lt;b&gt;Конец&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="25" y="834" width="210" height="36" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════
         ПРАВАЯ ПАНЕЛЬ — формула + коэффициенты
         ══════════════════════════════════════════ -->

    <!-- Рамка формулы -->
    <mxCell id="form_bg" value="" style="rounded=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;" vertex="1" parent="1">
      <mxGeometry x="510" y="42" width="310" height="230" as="geometry"/>
    </mxCell>
    <mxCell id="form_title" value="&lt;b&gt;Основная формула модели&lt;/b&gt;" style="text;html=1;fontSize=10;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="520" y="50" width="290" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="form_main" value="&lt;font style=&quot;font-size:20px;&quot;&gt;&lt;b&gt;Т = l/v + А·С + р·t&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="510" y="70" width="310" height="34" as="geometry"/>
    </mxCell>
    <mxCell id="form_d1" value="&lt;b&gt;l/v&lt;/b&gt;  — чистое время движения" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="108" width="290" height="18" as="geometry"/></mxCell>
    <mxCell id="form_d2" value="&lt;b&gt;А·С&lt;/b&gt;  — задержка от пробок и ДТП" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="126" width="290" height="18" as="geometry"/></mxCell>
    <mxCell id="form_d3" value="&lt;b&gt;р·t&lt;/b&gt;  — ожидаемая задержка из-за ДТП" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="144" width="290" height="18" as="geometry"/></mxCell>
    <mxCell id="form_v"  value="&lt;i&gt;V = V₀ × К_покр × К_погода × К_время&lt;/i&gt;" style="text;html=1;fontSize=9;fontColor=#000000;align=left;" vertex="1" parent="1"><mxGeometry x="520" y="168" width="290" height="18" as="geometry"/></mxCell>
