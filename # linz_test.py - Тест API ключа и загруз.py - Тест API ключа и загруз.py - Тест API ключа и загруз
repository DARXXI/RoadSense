def deg_to_tile(lat, lon, zoom):
    """Конвертирует градусы в номера тайлов XYZ"""
    n = 2.0 ** zoom
    xtile = int((lon + 180.0) / 360.0 * n)
    ytile = int((1.0 - math.asinh(math.tan(math.radians(lat))) / math.pi) / 2.0 * n)
    return xtile, ytile

def download_tile(zoom, x, y):
    """Скачивает один тайл с LINZ"""
    url = f"https://tiles-cdn.koordinates.com/services;key={API_KEY}/tiles/v4/layer={LAYER_ID}/EPSG:3857/{zoom}/{x}/{y}.png"
    
    headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)'}
    
    try:
        response = requests.get(url, headers=headers, timeout=30)
        if response.status_code == 200:
            return Image.open(BytesIO(response.content))
        else:
            print(f"   HTTP {response.status_code}")
            return None
    except Exception as e:
        print(f"   Ошибка: {e}")
        return None

def create_mosaic(zoom, center_x, center_y, radius=1):
    """
    Создает мозаику из тайлов вокруг центра
    
    radius=1 -> 3x3 тайла (9 шт)
    radius=2 -> 5x5 тайлов (25 шт)
    radius=3 -> 7x7 тайлов (49 шт)
    """
    mosaic_size = radius * 2 + 1
    total_tiles = mosaic_size ** 2
    print(f"\n🖼️  Создание мозаики {mosaic_size}x{mosaic_size} тайлов (всего {total_tiles} шт)")
    
    # Загружаем первый тайл для размера
    first_tile = download_tile(zoom, center_x, center_y)
    if not first_tile:
        print("❌ Не удалось загрузить центральный тайл")
        return None
    
    tile_width, tile_height = first_tile.size
    mosaic = Image.new('RGB', (tile_width * mosaic_size, tile_height * mosaic_size))
    
    success_count = 0
    for dy in range(-radius, radius + 1):
        for dx in range(-radius, radius + 1):
            x = center_x + dx
            y = center_y + dy
            print(f"   Тайл ({dx:+d},{dy:+d}) -> ({x},{y})...", end=" ")
            
            tile = download_tile(zoom, x, y)
            if tile:
                paste_x = (dx + radius) * tile_width
                paste_y = (dy + radius) * tile_height
                mosaic.paste(tile, (paste_x, paste_y))
                success_count += 1
                print("✅")
            else:
                print("❌")
    
    print(f"\n📊 Успешно загружено: {success_count}/{total_tiles} тайлов")
    return mosaic if success_count > 0 else None


